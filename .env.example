# ---- Application ----
APP_ENV=development
HTTP_PORT=8080

# ---- PostgreSQL ----
# Used by docker-compose for the postgres container
POSTGRES_USER=aisp
POSTGRES_PASSWORD=aisp_secret
POSTGRES_DB=ai_social_publisher

# DSN used by the application (host=localhost when running outside docker)
DATABASE_URL=postgres://aisp:aisp_secret@localhost:5432/ai_social_publisher?sslmode=disable

# ---- External services ----
NEWS_SERVICE_BASE_URL=http://localhost:9001
TELEGRAM_SERVICE_BASE_URL=http://localhost:9002

# ---- AI providers ----
TGPT_COMMAND=tgpt
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ---- Instagram Graph API ----
INSTAGRAM_ACCESS_TOKEN=changeme
IG_TECH_USER_ID=0000000000
IG_CINEMA_USER_ID=0000000000
IG_NEWS_USER_ID=0000000000
IG_ECONOMY_USER_ID=0000000000

# ---- Storage / public URL ----
PUBLIC_BASE_URL=http://localhost:8080/static
