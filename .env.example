# ---- Application ----
APP_ENV=development
HTTP_PORT=8080

# Replace both secrets before exposing the service. Minimum 32 characters.
API_AUTH_TOKEN=replace-with-a-random-api-token-32-chars
TELEGRAM_CALLBACK_SECRET=replace-with-random-callback-secret-32
TELEGRAM_ALLOWED_USER=gokhan

# ---- PostgreSQL ----
# Used by docker-compose for the postgres container
POSTGRES_USER=aisp
POSTGRES_PASSWORD=aisp_secret
POSTGRES_DB=ai_social_publisher
POSTGRES_PORT=5433

# DSN used by the application (host=localhost when running outside docker)
DATABASE_URL=postgres://aisp:aisp_secret@localhost:5433/ai_social_publisher?sslmode=disable

# ---- External services ----
NEWS_SERVICE_BASE_URL=http://localhost:9001
TELEGRAM_SERVICE_BASE_URL=http://localhost:9002
NEWS_SERVICE_AUTH_TOKEN=replace-with-news-service-token-32-chars
TELEGRAM_SERVICE_AUTH_TOKEN=replace-with-telegram-token-32-chars

# ---- AI providers ----
TGPT_COMMAND=tgpt
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ---- Instagram Graph API ----
INSTAGRAM_ACCESS_TOKEN=changeme
IG_TECH_USER_ID=0000000000
IG_CINEMA_USER_ID=0000000000
IG_NEWS_USER_ID=0000000000
IG_ECONOMY_USER_ID=0000000000

# ---- Storage / public URL ----
PUBLIC_BASE_URL=http://localhost:8080/static
